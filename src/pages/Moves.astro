---
import Layout from "@layouts/Layout.astro";
import Navbar from "@pages/Layouts/Navbar.astro";
import Footer from "@pages/Layouts/Footer.astro";
import MovesInfo from "@components/MovesInfo";
---

<Layout>
  <div class="flex flex-col min-h-screen">
    <Navbar />
    <main class="flex-grow pt-16 bg-[url('/BackgroundPokemon.jpg')]">
      <MovesInfo client:load />
    </main>
    <Footer />
  </div>
</Layout>
