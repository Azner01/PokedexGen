---
import Layout from "@layouts/Layout.astro";
import Navbar from "@pages/Layouts/Navbar.astro";
import Footer from "@pages/Layouts/Footer.astro";
import InfoMoves from "@components/InfoMoves";

const { pokeMoveName } = Astro.params;
---

<Layout>
  <div class="flex flex-col min-h-screen">
    <Navbar />
    <main class="flex-grow pt-16 bg-[url('/BackgroundPokemon.jpg')]">
      <InfoMoves dataMove={pokeMoveName} client:load />
    </main>
    <Footer />
  </div>
</Layout>
